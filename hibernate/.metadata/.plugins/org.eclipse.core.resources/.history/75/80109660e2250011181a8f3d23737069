package com.umfrancisco;

import java.util.Random;

public class Main {
	public static void main(String[] args) {
		String[] names = {"Ann", "Bob", "Carole", "Dave"};
		int size = names.length;
		for (int i = 0; i < 15; i++) {
			String name = names[new Random().nextInt(size)];
			String company;
			System.out.println(new User(name, company));
		}
	}
}

class User {
	private int id;
	private String name;
	private String email;
	private String company;
	
	public User(String name, String company) {
		this(new Random().nextInt(100, 999), name, company);
	}
	
	public User(int id, String name, String company) {
		this.id = id;
		this.name = name;
		this.company = company;
		this.email = "%s@%s.com".formatted(name.toLowerCase(), company.toLowerCase());
	}
	
	@Override
	public String toString() {
		return "(%d) %s - %s".formatted(id, name, email);
	}
}
