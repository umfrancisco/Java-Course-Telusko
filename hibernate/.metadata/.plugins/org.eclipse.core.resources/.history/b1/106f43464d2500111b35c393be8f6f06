package com.umfrancisco;

import java.util.Arrays;

public class Main {
	public static void main(String[] args) {
		toChar("Hello World in Java Programming Language");
	}
	
	public static int[] toInt(char[] data) {
		int size = data.length;
		int[] arr = new int[size];
		for (int i = 0; i < size; i++) {
			arr[i] = (int) data[i];
		}
	}
	
	public static char[] toChar(String data) {
		String str = removeEmptySpaces(data);
		int size = str.length();
		char[] arr = new char[size];
		for (int i = 0; i < size; i++) {
			arr[i] = str.charAt(i);
		}
		System.out.println(Arrays.toString(arr));
		return arr;
	}
	
	private static String removeEmptySpaces(String data) {
		String[] split = data.split(" ");
		String newStr = "";
		for (var str : split) {
			newStr += str;
		}
		return newStr;
	}
}
