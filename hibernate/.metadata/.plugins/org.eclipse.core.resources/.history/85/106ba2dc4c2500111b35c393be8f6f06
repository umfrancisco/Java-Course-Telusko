package com.umfrancisco;

import java.util.Arrays;

public class Main {
	public static void main(String[] args) {
		toChar("Hello World");
	}
	
	public static void toChar(String data) {
		String str = removeEmptySpaces(data);
		int size = str.length();
		String[] arr = new String[size];
		for (int i = 0; i < size; i++) {
			arr[i] = str.charAt(i)+""+i;
		}
		System.out.println(Arrays.toString(arr));
	}
	
	private static String removeEmptySpaces(String data) {
		String[] split = data.split(" ");
		String newStr = "";
		for (var str : split) {
			newStr += str;
		}
		return newStr;
	}
}
