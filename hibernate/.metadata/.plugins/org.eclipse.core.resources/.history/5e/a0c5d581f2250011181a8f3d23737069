// # MODIFYING TABLES AND COLUMNS

@Entity
@Table(name="alien_table")
public class Alien {
	
	@Id
	private int id;
	
	@Column(name="alien_name")
	private String name;
	
	@Transient
	private String tech;
	
	// getters, setters, toString
}

public class Main {
	public static void main(String[] args) {
		Alien a1 = new Alien();
		a1.setId(101);
		a1.setName("Navin");
		a1.setTech("Java");
		
		SessionFactory sf = new Configuration()
				.addAnnotatedClass(com.umfrancisco.Alien.class)
				.configure()
				.buildSessionFactory();
		
		Session session = sf.openSession();
		Transaction transaction = session.beginTransaction();
		
		session.persist(a1);
		transaction.commit();
		
		session.close();
		sf.close();
	}
}

